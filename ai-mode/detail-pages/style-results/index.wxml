<view class="page" style="padding-top: {{headerPaddingTop}}px">
  <text class="page-title">{{title}}</text>
  <view class="result-list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="result-row"
      data-item="{{item}}"
      bindtap="onTapStyle"
    >
      <text class="result-code">{{item.kind === 'extension' ? '扩展' : item.code}}</text>
      <view class="result-copy">
        <text class="result-name">{{item.displayName}}</text>
        <text class="result-en">{{item.name_en}}</text>
      </view>
      <text class="result-action">选择</text>
    </view>
  </view>
</view>
