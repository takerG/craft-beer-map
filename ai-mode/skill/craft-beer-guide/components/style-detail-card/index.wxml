<view class="card-shell" wx:if="{{style}}">
  <view class="detail-head">
    <view class="kind-pill">{{style.kind === 'extension' ? '市场扩展' : style.code}}</view>
    <text class="source-label">{{detail.sourceLabel}}</text>
  </view>
  <text class="style-name">{{style.displayName}}</text>
  <text class="style-en">{{style.name_en}}</text>
  <text class="summary">{{summary}}</text>
  <view class="action-row">
    <view
      class="secondary-action"
      hover-class="tap-hover"
      hover-stay-time="80"
      bindtap="onTapDetail"
    >查看完整详情</view>
    <view
      class="primary-action"
      hover-class="tap-hover"
      hover-stay-time="80"
      bindtap="onTapFavorite"
    >加入收藏</view>
  </view>
</view>
