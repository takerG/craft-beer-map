<view class="card-shell">
  <view class="card-head">
    <text class="card-title">{{title}}</text>
    <text class="card-count">{{total}} 个</text>
  </view>
  <view class="style-list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="style-row"
      data-item="{{item}}"
      bindtap="onTapStyle"
    >
      <text class="style-code">{{item.kind === 'extension' ? '扩展' : item.code}}</text>
      <view class="style-copy">
        <text class="style-name">{{item.displayName}}</text>
        <text class="style-en">{{item.name_en}}</text>
      </view>
      <text class="row-action">查看</text>
    </view>
  </view>
  <view wx:if="{{hasMore}}" class="more-action" bindtap="onTapMore">查看全部结果</view>
</view>
