        "additionalProperties": false,
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "slug": { "type": "string" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "type": { "type": "string" },
                "difficulty": { "type": "string" },
                "readingTime": { "type": "number" },
                "tags": { "type": "array", "items": { "type": "string" } },
                "relatedStyles": { "type": "array", "items": { "type": "string" } },
                "publishedAt": { "type": "string" },
                "route": { "type": "string" }
              },
              "required": [
                "slug", "title", "description", "type", "difficulty", "readingTime",
                "tags", "relatedStyles", "publishedAt", "route"
              ]
            }
          },
          "total": { "type": "integer", "minimum": 0 },
          "keyword": { "type": "string" }
        },
        "required": ["items", "total", "keyword"]
      },
      "_meta": { "ui": { "componentPath": "components/academy-article-list-card/index" } }
    }
