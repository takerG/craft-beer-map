.favorites-page {
  padding-bottom: 64rpx;
}

.favorite-hero {
  position: relative;
  padding: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-left: 10rpx solid #f6ad55;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(246, 173, 85, 0.18) 0, transparent 240rpx),
    linear-gradient(145deg, #202b3b 0%, #151f2c 68%, #101720 100%);
}

.favorite-count {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  margin-top: 24rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #ffcf85;
  font-size: 22rpx;
  font-weight: 900;
}

.favorite-status {
  display: flex;
  align-items: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  color: #cbd5e1;
  font-size: 23rpx;
  line-height: 1.5;
}

.favorite-status-error {
  justify-content: space-between;
  color: #ffcf85;
}

.retry-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-left: 20rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.favorite-list {
  margin-top: 28rpx;
}

.favorite-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 124rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-left-width: 8rpx;
  border-radius: 14rpx;
  background: #182231;
  text-align: left;
}

.favorite-code {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  height: 76rpx;
  margin-right: 18rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 24rpx;
  font-weight: 900;
}

.favorite-main {
  flex: 1;
  min-width: 0;
}

.favorite-name {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-en {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #9aa8bb;
  font-size: 22rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-row-actions {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
}

.favorite-action {
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 900;
}

.favorite-remove {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 8rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #d7deea;
  font-size: 22rpx;
  font-weight: 800;
}

.empty-state {
  margin-top: 36rpx;
  padding: 42rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
  text-align: center;
}

.empty-title {
  display: block;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-copy {
  display: block;
  margin-top: 14rpx;
  color: #9aa8bb;
  font-size: 24rpx;
  line-height: 1.6;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}
