<view class="page academy-page">
  <view class="academy-head">
    <view class="academy-title-line">
      <text class="page-title">{{title}}</text>
      <text class="page-subtitle academy-title-subtitle">{{subtitle}}</text>
    </view>
  </view>

  <view wx:if="{{isLoading}}" class="academy-empty">
    <text>正在加载学院内容</text>
  </view>

  <view wx:if="{{isError}}" class="academy-empty">
    <text class="academy-empty-title">学院内容暂时没有加载成功</text>
    <text class="academy-empty-copy" user-select="true">请稍后重试，当前不会展示未校验的远端内容。</text>
    <view class="academy-empty-action" hover-class="tap-hover" hover-stay-time="80" bindtap="retryAcademyHome">重试</view>
  </view>

  <scroll-view wx:if="{{isReady}}" class="filter-strip" scroll-x="true" show-scrollbar="false">
    <view
      wx:for="{{typeFilters}}"
      wx:key="type"
      class="feed-filter {{item.className}}"
      data-type="{{item.type}}"
      hover-class="tap-hover"
      hover-stay-time="80"
      bindtap="filterArticles"
    >
      <text>{{item.label}}</text>
      <text>{{item.count}}</text>
    </view>
  </scroll-view>

  <view wx:if="{{isReady}}" class="feed-list">
    <view
      wx:for="{{feedSites}}"
      wx:key="slug"
      class="feed-card"
      style="border-left-color: {{item.accent}}"
      data-slug="{{item.slug}}"
      hover-class="tap-hover"
      hover-stay-time="80"
      bindtap="openArticle"
    >
      <view class="feed-meta">
        <text>{{item.publishedAt}}</text>
        <text>{{item.readingTime}} min</text>
      </view>
      <text class="feed-title">{{item.title}}</text>
      <text class="feed-desc">{{item.description}}</text>
      <view class="feed-tags">
        <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>
    </view>
  </view>
</view>

<ai-entry
  prompt="帮我找一篇适合现在阅读的精酿学院文章"
  context-type="academy"
  context-data="{{activeType}}"
/>
