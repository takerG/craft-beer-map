.academy-page {
  padding-bottom: 56rpx;
  background: #10151d;
}

.academy-head {
  margin-bottom: 20rpx;
}

.academy-empty {
  padding: 44rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.055);
  color: #a9b5c7;
  font-size: 24rpx;
  line-height: 1.7;
}

.academy-empty-title {
  display: block;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 850;
}

.academy-empty-copy {
  display: block;
  margin-top: 12rpx;
}

.academy-empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  margin-top: 22rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #f6ad55;
  color: #172231;
  font-size: 24rpx;
  font-weight: 850;
}

.feed-list {
  width: 100%;
}

.filter-strip {
  width: 100%;
  height: 58rpx;
  margin: 0 0 20rpx;
  overflow: hidden;
  line-height: 58rpx;
  white-space: nowrap;
}

.feed-filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.055);
  color: #a9b5c7;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 58rpx;
  vertical-align: top;
}

.feed-filter text {
  display: inline-block;
}

.feed-filter text + text {
  margin-left: 10rpx;
  color: #f6ad55;
  font-size: 19rpx;
}

.feed-filter.is-active {
  border-color: rgba(246, 173, 85, 0.72);
  background: rgba(246, 173, 85, 0.14);
  color: #f8fafc;
}

.feed-card {
  width: 100%;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-left-width: 8rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025)),
    #172231;
}

.feed-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #8d9aad;
  font-size: 20rpx;
  line-height: 1.3;
}

.feed-title {
  display: -webkit-box;
  margin-top: 14rpx;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.25;
  text-overflow: ellipsis;
}

.feed-desc {
  display: block;
  margin-top: 10rpx;
  color: #a9b5c7;
  font-size: 23rpx;
  line-height: 1.55;
}

.feed-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.feed-tags text {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  margin: 0 8rpx 8rpx 0;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #cbd5e1;
  font-size: 19rpx;
}
