<view class="page search-page">
  <view class="search-box">
    <input
      value="{{query}}"
      focus="{{inputFocused}}"
      placeholder="输入编号、中英文名或常见叫法"
      placeholder-class="search-placeholder"
      bindinput="onInput"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      bindconfirm="submitSearch"
      confirm-type="search"
    />
    <button wx:if="{{query}}" class="clear-btn" hover-class="tap-hover" hover-stay-time="80" bindtap="clearSearch">清除</button>
  </view>

  <view wx:if="{{!hasQuery}}" class="empty-state">
    <text class="empty-title">搜索风格</text>
    <text class="empty-copy">可搜索 BJCP 编号、中英文名与常见叫法，结果会直接进入对应详情页。</text>
    <text class="empty-copy">资料同时覆盖 BJCP 官方标准风格与 BA/WBC/GABF 市场扩展风格。</text>
    <view class="suggestion-list">
      <text
        wx:for="{{suggestions}}"
        wx:key="*this"
        class="suggestion-chip"
        hover-class="tap-hover"
        hover-stay-time="80"
        data-query="{{item}}"
        bindtap="useSuggestion"
      >{{item}}</text>
    </view>
  </view>

  <view wx:elif="{{!hasResults}}" class="empty-state">
    <text class="empty-title">没有找到匹配风格</text>
    <text class="empty-copy">当前资料覆盖 BJCP 官方标准风格与 BA/WBC/GABF 市场扩展风格。</text>
    <text class="empty-copy">可以换一个编号、中文关键词、英文名称或常见叫法再试。</text>
    <view class="empty-action" hover-class="tap-hover" hover-stay-time="80" bindtap="restartSearch">清空重新搜索</view>
  </view>

  <view wx:else class="result-list">
    <text wx:if="{{resultCountLabel}}" class="result-count">{{resultCountLabel}}</text>
    <view
      wx:for="{{results}}"
      wx:key="id"
      class="result-row"
      hover-class="tap-hover"
      hover-stay-time="80"
      data-style-id="{{item.id}}"
      data-item-kind="{{item.kind}}"
      bindtap="openStyle"
    >
      <text class="result-code" wx:if="{{item.kind !== 'extension'}}">{{item.code}}</text>
      <text class="result-code result-kind" wx:else>扩展风格</text>
      <view class="result-main">
        <text class="result-name">{{item.displayName}}</text>
        <text class="result-en">{{item.name_en}}</text>
        <text wx:if="{{item.kind === 'extension'}}" class="result-source">{{item.sourceLabel}}</text>
        <view wx:if="{{item.aliases.length}}" class="result-alias-list">
          <text
            wx:for="{{item.aliases}}"
            wx:for-item="alias"
            wx:key="*this"
            class="result-alias"
          >{{alias}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<ai-entry
  prompt="帮我搜索这个啤酒风格或常见叫法"
  context-type="search"
  context-data="{{query}}"
/>
