<view class="page academy-article-page {{article.pageThemeClass}}">
  <view wx:if="{{isLoading}}" class="empty-state">
    <text>正在打开学院内容</text>
  </view>

  <view wx:if="{{isNotFound}}" class="empty-state">
    <text class="empty-title">没有找到这篇学院内容</text>
    <text class="empty-copy" user-select="true">可能是内容目录还没有生成，回到学院看看其他内容。</text>
    <view class="empty-action" hover-class="tap-hover" hover-stay-time="80" bindtap="backToAcademy">回到学院</view>
  </view>

  <view wx:if="{{isError}}" class="empty-state">
    <text class="empty-title">学院内容暂时没有加载成功</text>
    <text class="empty-copy" user-select="true">请稍后重试，当前不会展示未校验的远端内容。</text>
    <view class="empty-action" hover-class="tap-hover" hover-stay-time="80" bindtap="retryArticle">重试</view>
  </view>

  <view wx:if="{{isReady}}">
    <view wx:if="{{article.isColdIpaExperience}}" class="cold-ipa-hero">
      <view class="cold-ipa-hero-copy">
        <text class="cold-ipa-title">{{article.title}}</text>
        <text class="cold-ipa-summary" user-select="true">{{article.hero.summary}}</text>
        <view class="cold-ipa-meta">
          <text>{{article.difficulty}}</text>
          <text>{{article.readingTime}} min</text>
          <text>{{article.heroMetric}}</text>
        </view>
      </view>
      <view class="cold-ipa-glass">
        <view class="glass-foam"></view>
        <view class="glass-beer"></view>
        <view class="glass-bubbles">
          <text></text>
          <text></text>
          <text></text>
        </view>
      </view>
    </view>

    <view wx:if="{{article.showDefaultArticleHero}}" class="article-hero" style="border-top-color: {{article.accent}}">
      <text class="article-kicker">{{article.hero.kicker}}</text>
      <text class="page-title">{{article.title}}</text>
      <text class="page-subtitle" user-select="true">{{article.hero.summary}}</text>
      <view class="article-meta">
        <text>{{article.difficulty}}</text>
        <text>{{article.readingTime}} min</text>
        <text>{{article.heroMetric}}</text>
      </view>
    </view>

    <view class="article-body">
      <view wx:for="{{articleSections}}" wx:for-item="section" wx:key="id" class="article-section">
        <text class="article-section-title">{{section.title}}</text>
        <text wx:for="{{section.paragraphs}}" wx:for-item="paragraph" wx:key="*this" class="article-paragraph" user-select="true">{{paragraph}}</text>
        <view wx:if="{{section.hasCallout}}" class="article-callout">
          <text>{{section.callout}}</text>
        </view>

        <view wx:if="{{section.showIpaMapExperience}}" class="ipa-map-experience experience-section">
          <view class="ipa-map-canvas">
            <view class="map-axis map-axis-x"></view>
            <view class="map-axis map-axis-y"></view>
            <text class="map-label map-label-left">清爽</text>
            <text class="map-label map-label-right">饱满</text>
            <text class="map-label map-label-top">香气强</text>
            <text class="map-label map-label-bottom">苦味利落</text>
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="ipa-node {{item.className}}"
              style="{{item.positionStyle}}"
              data-branch-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectIpaBranch"
            >
              <text>{{item.title}}</text>
            </view>
          </view>
          <view class="experience-focus">
            <text class="focus-title">{{article.experience.activeItem.title}}</text>
            <text class="focus-kicker">{{article.experience.activeItem.axis}}</text>
            <text class="focus-copy" user-select="true">{{article.experience.activeItem.body}}</text>
          </view>
        </view>

        <view wx:if="{{section.showAleLagerExperience}}" class="ale-lager-experience experience-section">
          <view class="path-switch">
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="path-option {{item.className}}"
              data-path-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectFermentationPath"
            >
              <text>{{item.title}}</text>
              <text user-select="true">{{item.lead}}</text>
            </view>
          </view>
          <view class="path-timeline">
            <view wx:for="{{article.experience.activeItem.steps}}" wx:for-item="step" wx:key="*this" class="path-step">
              <text class="step-dot"></text>
              <text user-select="true">{{step}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{section.showFlavorRadarExperience}}" class="flavor-radar-experience experience-section">
          <view class="radar-field">
            <view class="radar-ring radar-ring-outer"></view>
            <view class="radar-ring radar-ring-inner"></view>
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="source-orbit {{item.className}}"
              style="{{item.angleStyle}}"
              data-source-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectFlavorSource"
            >
              <text>{{item.title}}</text>
            </view>
          </view>
          <view class="term-board">
            <text class="focus-title">{{article.experience.activeItem.title}}</text>
            <text class="focus-copy" user-select="true">{{article.experience.activeItem.clue}}</text>
            <view class="term-list">
              <text wx:for="{{article.experience.activeItem.terms}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{section.showColdIpaComparison}}" class="cold-ipa-comparison">
          <view class="cold-companion-head">
            <text>{{section.companion.title}}</text>
            <text user-select="true">{{section.companion.summary}}</text>
          </view>
          <view class="cold-style-tabs">
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="cold-style-tab {{item.className}}"
              data-comparison-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectColdIpaComparison"
            >
              <text>{{item.title}}</text>
            </view>
          </view>
          <view class="cold-style-focus">
            <text class="cold-focus-title">{{article.experience.activeItem.title}}</text>
            <text class="cold-focus-lead" user-select="true">{{article.experience.activeItem.lead}}</text>
            <view class="cold-compare-rows">
              <view wx:for="{{article.experience.activeItem.rows}}" wx:for-item="row" wx:key="label" class="cold-compare-row">
                <text>{{row.label}}</text>
                <text user-select="true">{{row.value}}</text>
              </view>
            </view>
          </view>
        </view>

        <view wx:if="{{section.showColdIpaProcess}}" class="cold-ipa-process">
          <view class="cold-companion-head">
            <text>{{section.companion.title}}</text>
            <text user-select="true">{{section.companion.summary}}</text>
          </view>
          <view class="cold-process-list">
            <view wx:for="{{section.companion.processSteps}}" wx:for-item="step" wx:key="title" class="cold-process-step">
              <text class="cold-process-marker">{{step.marker}}</text>
              <view class="cold-process-copy">
                <text>{{step.title}}</text>
                <text user-select="true">{{step.body}}</text>
              </view>
            </view>
          </view>
        </view>

        <view wx:if="{{section.showColdIpaChecklist}}" class="cold-ipa-checklist">
          <text class="cold-check-title">{{section.companion.title}}</text>
          <view class="cold-check-list">
            <view wx:for="{{section.companion.checkItems}}" wx:for-item="check" wx:key="marker" class="cold-check-item">
              <text>{{check.marker}}</text>
              <text user-select="true">{{check.label}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{article.hasGenericModules}}" class="generic-sections">
      <view wx:for="{{article.genericModules}}" wx:for-item="module" wx:key="id" class="generic-module">
        <text class="generic-module-title">{{module.title}}</text>
        <text wx:if="{{module.summary}}" class="generic-module-summary" user-select="true">{{module.summary}}</text>

        <view wx:if="{{module.isTermGrid}}" class="term-grid">
          <view wx:for="{{module.items}}" wx:for-item="term" wx:key="title" class="term-card">
            <view class="term-card-head">
              <text>{{term.title}}</text>
              <text>{{term.label}}</text>
            </view>
            <text class="term-card-body" user-select="true">{{term.body}}</text>
          </view>
        </view>

        <view wx:if="{{module.isComparison}}" class="generic-comparison">
          <view wx:for="{{module.columns}}" wx:for-item="column" wx:key="title" class="generic-column">
            <text class="generic-column-title">{{column.title}}</text>
            <text wx:for="{{column.items}}" wx:for-item="copy" wx:key="*this" class="generic-column-item" user-select="true">{{copy}}</text>
          </view>
        </view>

        <view wx:if="{{module.isScale}}" class="generic-scale">
          <view wx:for="{{module.points}}" wx:for-item="point" wx:key="label" class="generic-scale-row">
            <view class="generic-scale-head">
              <text>{{point.label}}</text>
              <text>{{point.low}} / {{point.high}}</text>
            </view>
            <view class="generic-scale-track">
              <view class="generic-scale-fill" style="{{point.levelStyle}}"></view>
            </view>
          </view>
        </view>

        <view wx:if="{{module.isChecklist}}" class="generic-checklist">
          <view wx:for="{{module.items}}" wx:for-item="check" wx:key="title" class="check-row">
            <text class="check-marker">{{check.marker}}</text>
            <view class="check-copy">
              <text>{{check.title}}</text>
              <text user-select="true">{{check.body}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{module.isQuiz}}" class="generic-quiz">
          <text class="generic-quiz-question" user-select="true">{{module.question}}</text>
          <block wx:for="{{module.options}}" wx:for-item="option" wx:key="label">
            <view wx:if="{{option.correct}}" class="quiz-option quiz-option-correct">
              <text>{{option.label}}</text>
              <text user-select="true">{{option.feedback}}</text>
            </view>
            <view wx:if="{{option.isIncorrect}}" class="quiz-option">
              <text>{{option.label}}</text>
              <text user-select="true">{{option.feedback}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="section-head">
      <text>关联风格</text>
      <text>继续阅读</text>
    </view>

    <view class="related-list">
      <view
        wx:for="{{article.relatedStyles}}"
        wx:key="id"
        class="related-row"
        style="border-left-color: {{item.color}}"
        data-style-id="{{item.id}}"
        data-item-kind="{{item.kind}}"
        hover-class="tap-hover"
        hover-stay-time="80"
        bindtap="openRelatedStyle"
      >
        <text class="related-code">{{item.codeLabel}}</text>
        <view class="related-main">
          <text class="related-name">{{item.displayName}}</text>
          <text class="related-en" user-select="true">{{item.name_en}}</text>
        </view>
        <text class="related-action">查看</text>
      </view>
    </view>
  </view>
</view>

<ai-entry
  prompt="围绕当前文章继续解释，并推荐相关风格"
  context-type="academy-article"
  context-data="{{article.slug}}"
/>
