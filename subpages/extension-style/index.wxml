<view class="page extension-style-page" wx:if="{{loadStatus === 'loading'}}">
  <view class="state-card">
    <text class="state-title">正在加载扩展风格</text>
    <text class="state-copy">准备市场叫法、定义和 BJCP 对照。</text>
  </view>
</view>

<view class="page extension-style-page" wx:elif="{{loadStatus === 'not-found'}}">
  <view class="state-card">
    <text class="state-title">没有找到这个扩展风格</text>
    <text class="state-copy">{{errorMessage}}</text>
    <view class="state-action" hover-class="tap-hover" hover-stay-time="80" bindtap="goSearch">去搜索</view>
  </view>
</view>

<view class="page extension-style-page" wx:elif="{{loadStatus === 'error'}}">
  <view class="state-card">
    <text class="state-title">详情加载失败</text>
    <text class="state-copy">{{errorMessage}}</text>
    <view class="state-action" hover-class="tap-hover" hover-stay-time="80" bindtap="goSearch">去搜索</view>
  </view>
</view>

<view class="page extension-style-page" wx:elif="{{detail}}">
  <ai-entry
    prompt="解释当前市场扩展风格，并对照接近的 BJCP 风格"
    context-type="extension-style"
    context-data="{{detail.style}}"
  />

  <view class="style-hero" style="border-left-color: {{detail.style.color}}">
    <view class="style-hero-head">
      <text class="style-code">扩展风格</text>
      <view
        class="favorite-action {{isFavorite ? 'favorite-action-active' : ''}}"
        hover-class="tap-hover"
        hover-stay-time="80"
        bindtap="toggleFavorite"
      >
        <text>{{favoriteActionLabel}}</text>
      </view>
    </view>
    <text class="style-name">{{detail.style.displayName}}</text>
    <text class="style-en">{{detail.style.name_en}}</text>
    <text class="style-source">{{detail.sourceLabel}}</text>
    <view class="style-path" hover-class="tap-hover" hover-stay-time="80" bindtap="openGroup">
      <text>返回扩展分组</text>
      <text>{{detail.group.name}}</text>
    </view>
  </view>

  <view wx:if="{{!contentReady}}" class="content-skeleton">
    <view class="skeleton-line skeleton-strong"></view>
    <view class="skeleton-line"></view>
    <view class="skeleton-line skeleton-short"></view>
  </view>

  <block wx:else>
    <view wx:if="{{detail.style.aliases.length}}" class="detail-section">
      <text class="detail-title">常用叫法</text>
      <view class="alias-list">
        <text
          wx:for="{{detail.style.aliases}}"
          wx:for-item="alias"
          wx:key="*this"
          class="alias"
        >{{alias}}</text>
      </view>
    </view>

    <view class="reading-section">
      <text class="detail-title">市场定义</text>
      <text class="detail-body">{{detail.description}}</text>
    </view>

    <view class="reading-section">
      <text class="detail-title">BJCP 对照说明</text>
      <text class="detail-body">{{detail.bjcp_note}}</text>
    </view>

    <view wx:if="{{detail.bjcp_refs.length}}" class="detail-section">
      <text class="detail-title">近似 BJCP 入口</text>
      <view
        wx:for="{{detail.bjcp_refs}}"
        wx:key="id"
        class="bjcp-row"
        hover-class="tap-hover"
        hover-stay-time="80"
        data-style-id="{{item.id}}"
        bindtap="openBjcpStyle"
      >
        <text class="bjcp-code">{{item.code}}</text>
        <view class="bjcp-main">
          <text class="bjcp-name">{{item.displayName}}</text>
          <text class="bjcp-en">{{item.name_en}}</text>
        </view>
        <text class="bjcp-action">学习</text>
      </view>
    </view>
  </block>
</view>
