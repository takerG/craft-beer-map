.academy-page {
  padding-bottom: 56rpx;
  background: #10151d;
}

.feed-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.feed-head > view {
  flex: 1;
  min-width: 0;
}

.feed-count {
  flex: 0 0 auto;
  margin-left: 20rpx;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.4;
}

.feed-list {
  width: 100%;
}

.filter-strip {
  display: flex;
  width: 100%;
  margin: 0 0 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.feed-filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.055);
  color: #a9b5c7;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 58rpx;
}

.feed-filter text {
  display: inline-block;
}

.feed-filter text + text {
  margin-left: 10rpx;
  color: #f6ad55;
  font-size: 19rpx;
}

.feed-filter.is-active {
  border-color: rgba(246, 173, 85, 0.72);
  background: rgba(246, 173, 85, 0.14);
  color: #f8fafc;
}

.feed-card {
  width: 100%;
  min-height: 484rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-left-width: 8rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025)),
    #172231;
}

.feed-cover {
  display: block;
  width: 100%;
  height: 252rpx;
  margin-bottom: 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
}

.feed-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #8d9aad;
  font-size: 20rpx;
  line-height: 1.3;
}

.feed-title {
  display: block;
  margin-top: 14rpx;
  overflow: hidden;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 950;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-desc {
  display: block;
  margin-top: 10rpx;
  color: #a9b5c7;
  font-size: 23rpx;
  line-height: 1.55;
}

.feed-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.feed-tags text {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  margin: 0 8rpx 8rpx 0;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #cbd5e1;
  font-size: 19rpx;
}
