<view class="page style-page" wx:if="{{loadStatus === 'loading'}}">
  <view class="state-card">
    <text class="state-title">正在加载风格详情</text>
    <text class="state-copy">准备风味描述、参数和关联风格。</text>
  </view>
</view>

<view class="page style-page" wx:elif="{{loadStatus === 'not-found'}}">
  <view class="state-card">
    <text class="state-title">没有找到这个风格</text>
    <text class="state-copy">{{errorMessage}}</text>
    <view class="state-action" hover-class="tap-hover" hover-stay-time="80" bindtap="goSearch">去搜索</view>
  </view>
</view>

<view class="page style-page" wx:elif="{{loadStatus === 'error'}}">
  <view class="state-card">
    <text class="state-title">详情加载失败</text>
    <text class="state-copy">{{errorMessage}}</text>
    <view class="state-action" hover-class="tap-hover" hover-stay-time="80" bindtap="goSearch">去搜索</view>
  </view>
</view>

<view class="page style-page" wx:elif="{{detail}}">
  <view class="style-hero" style="border-left-color: {{detail.style.color}}">
    <text class="style-code">{{detail.style.code}}</text>
    <text class="style-name">{{detail.style.displayName}}</text>
    <text class="style-en">{{detail.style.name_en}}</text>
    <view class="style-path" hover-class="tap-hover" hover-stay-time="80" bindtap="openGroup">
      <text>返回风格大类</text>
      <text>{{detail.category.id}} {{detail.category.name_zh}} · {{detail.group.name}}</text>
    </view>
  </view>

  <view wx:if="{{!contentReady}}" class="content-skeleton">
    <view class="skeleton-line skeleton-strong"></view>
    <view class="skeleton-line"></view>
    <view class="skeleton-line skeleton-short"></view>
  </view>

  <block wx:else>
    <view wx:if="{{detail.style.aliases.length}}" class="detail-section alias-section">
      <text class="detail-title">常用叫法</text>
      <view class="alias-list">
        <text
          wx:for="{{detail.style.aliases}}"
          wx:for-item="alias"
          wx:key="*this"
          class="alias"
        >{{alias}}</text>
      </view>
    </view>

    <view wx:if="{{detail.stats.length}}" class="stats-grid">
      <view wx:for="{{detail.stats}}" wx:key="label" class="stat-card">
        <text>{{item.label}}</text>
        <text>{{item.value}}</text>
      </view>
    </view>

    <view class="reading-section" wx:for="{{detail.sections}}" wx:key="key">
      <text class="detail-title">{{item.label}}</text>
      <text class="detail-body">{{item.content}}</text>
    </view>

    <view wx:if="{{detail.tags.length}}" class="detail-section">
      <text class="detail-title">标签</text>
      <view class="tag-list">
        <text wx:for="{{detail.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{detail.related.length}}" class="detail-section">
      <text class="detail-title">关联风格</text>
      <view
        wx:for="{{detail.related}}"
        wx:key="styleId"
        class="related-row"
        hover-class="tap-hover"
        hover-stay-time="80"
        data-style-id="{{item.styleId}}"
        bindtap="openRelated"
      >
        <text class="related-type">{{item.label}}</text>
        <text class="related-name">{{item.styleCode}} {{item.styleName}}</text>
        <text class="related-action">查看</text>
      </view>
    </view>
  </block>
</view>
