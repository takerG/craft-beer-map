.extension-group-page {
  padding-bottom: 64rpx;
}

.state-card {
  padding: 46rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
  text-align: center;
}

.state-title {
  display: block;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 800;
}

.state-copy {
  display: block;
  margin-top: 14rpx;
  color: #9aa8bb;
  font-size: 24rpx;
  line-height: 1.6;
}

.state-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.group-hero {
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-left-width: 10rpx;
  border-radius: 16rpx;
  background: #182231;
}

.group-kicker {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}

.group-name {
  display: block;
  margin-top: 22rpx;
  color: #f8fafc;
  font-size: 40rpx;
  font-weight: 850;
  line-height: 1.22;
}

.group-en,
.group-summary,
.group-count {
  display: block;
  margin-top: 10rpx;
  color: #a9b5c7;
  font-size: 24rpx;
  line-height: 1.55;
}

.group-count {
  color: #f6ad55;
  font-weight: 800;
}

.extension-list {
  margin-top: 22rpx;
}

.extension-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 128rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: #151f2c;
  text-align: left;
}

.extension-dot {
  flex: 0 0 16rpx;
  width: 16rpx;
  height: 72rpx;
  margin-right: 18rpx;
  border-radius: 999rpx;
}

.extension-main {
  flex: 1;
  min-width: 0;
}

.extension-name {
  display: block;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
}

.extension-en,
.extension-source {
  display: block;
  margin-top: 7rpx;
  color: #9aa8bb;
  font-size: 22rpx;
  line-height: 1.35;
}

.extension-source {
  color: #f6ad55;
}

.extension-action {
  margin-left: 16rpx;
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}
