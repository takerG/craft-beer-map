.academy-article-page {
  padding-bottom: 56rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(83, 212, 218, 0.16) 0, rgba(83, 212, 218, 0.05) 220rpx, transparent 410rpx),
    radial-gradient(circle at 90% 12%, rgba(246, 173, 85, 0.17) 0, rgba(246, 173, 85, 0.05) 210rpx, transparent 380rpx),
    linear-gradient(180deg, #101722 0%, #0d1118 58%, #10151d 100%);
}

.article-hero {
  padding: 34rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-top-width: 8rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025)),
    #172231;
  box-shadow: 0 22rpx 58rpx rgba(0, 0, 0, 0.24);
}

.article-kicker {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 900;
}

.article-hero .page-title {
  display: block;
  margin-top: 18rpx;
  color: #f8fafc;
  font-size: 46rpx;
  font-weight: 950;
  line-height: 1.18;
}

.article-hero .page-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #d6dfeb;
  font-size: 25rpx;
  line-height: 1.65;
}

.article-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.article-meta text {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  margin: 0 10rpx 10rpx 0;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #cbd5e1;
  font-size: 20rpx;
}

.article-body {
  margin-top: 28rpx;
}

.article-section {
  margin-bottom: 28rpx;
  padding: 28rpx 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.035);
}

.article-section-title {
  display: block;
  color: #f8fafc;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.28;
}

.article-paragraph {
  display: block;
  margin-top: 18rpx;
  color: #d6dfeb;
  font-size: 25rpx;
  line-height: 1.72;
}

.article-callout {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-left: 6rpx solid #f6ad55;
  border-radius: 14rpx;
  background: rgba(246, 173, 85, 0.1);
}

.article-callout text {
  display: block;
  color: #ffcf85;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.55;
}

.experience-section {
  margin-top: 28rpx;
}

.ipa-map-experience {
  padding-top: 0;
}

.ale-lager-experience {
  padding-top: 0;
}

.flavor-radar-experience {
  padding-top: 0;
}

.ipa-map-canvas,
.radar-field,
.path-switch,
.path-timeline,
.experience-focus,
.term-board {
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025)),
    #172231;
}

.ipa-map-canvas {
  position: relative;
  width: 100%;
  height: 460rpx;
  overflow: hidden;
}

.map-axis {
  position: absolute;
  background: rgba(255, 255, 255, 0.12);
}

.map-axis-x {
  left: 56rpx;
  right: 56rpx;
  top: 50%;
  height: 2rpx;
}

.map-axis-y {
  top: 52rpx;
  bottom: 52rpx;
  left: 50%;
  width: 2rpx;
}

.map-label {
  position: absolute;
  color: #8390a2;
  font-size: 20rpx;
  font-weight: 800;
}

.map-label-left {
  left: 24rpx;
  top: 48%;
}

.map-label-right {
  right: 24rpx;
  top: 48%;
}

.map-label-top {
  left: 44%;
  top: 22rpx;
}

.map-label-bottom {
  left: 40%;
  bottom: 22rpx;
}

.ipa-node {
  position: absolute;
  width: 166rpx;
  min-height: 66rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(246, 173, 85, 0.32);
  border-radius: 16rpx;
  background: rgba(246, 173, 85, 0.13);
  color: #ffcf85;
  font-size: 20rpx;
  font-weight: 950;
  line-height: 1.25;
  text-align: center;
}

.branch-item-active {
  border-color: rgba(83, 212, 218, 0.8);
  background: rgba(83, 212, 218, 0.2);
  color: #f8fafc;
}

.experience-focus,
.term-board {
  margin-top: 18rpx;
  padding: 24rpx;
}

.focus-title {
  display: block;
  color: #f8fafc;
  font-size: 32rpx;
  font-weight: 950;
  line-height: 1.25;
}

.focus-kicker {
  display: block;
  margin-top: 10rpx;
  color: #ffcf85;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.45;
}

.focus-copy {
  display: block;
  margin-top: 14rpx;
  color: #cbd5e1;
  font-size: 23rpx;
  line-height: 1.62;
}

.path-switch {
  display: flex;
  padding: 12rpx;
}

.path-option {
  flex: 1;
  min-width: 0;
  min-height: 156rpx;
  padding: 22rpx;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
}

.path-option + .path-option {
  margin-left: 12rpx;
}

.path-option text:first-child {
  display: block;
  color: #f8fafc;
  font-size: 29rpx;
  font-weight: 950;
}

.path-option text:last-child {
  display: block;
  margin-top: 12rpx;
  color: #a9b5c7;
  font-size: 21rpx;
  line-height: 1.5;
}

.path-item-active {
  border-color: rgba(83, 212, 218, 0.52);
  background: rgba(83, 212, 218, 0.12);
}

.path-timeline {
  margin-top: 18rpx;
  padding: 24rpx 24rpx 12rpx;
}

.path-step {
  display: flex;
  align-items: flex-start;
  min-height: 58rpx;
  color: #d6dfeb;
  font-size: 24rpx;
  line-height: 1.45;
}

.step-dot {
  flex: 0 0 18rpx;
  width: 18rpx;
  height: 18rpx;
  margin: 8rpx 18rpx 0 0;
  border-radius: 50%;
  background: #f6ad55;
}

.radar-field {
  position: relative;
  width: 100%;
  height: 468rpx;
  overflow: hidden;
}

.radar-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.radar-ring-outer {
  width: 330rpx;
  height: 330rpx;
  margin: -165rpx 0 0 -165rpx;
}

.radar-ring-inner {
  width: 176rpx;
  height: 176rpx;
  margin: -88rpx 0 0 -88rpx;
}

.source-orbit {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 82rpx;
  border: 1rpx solid rgba(83, 212, 218, 0.3);
  border-radius: 999rpx;
  background: rgba(83, 212, 218, 0.12);
  color: #bff9fb;
  font-size: 23rpx;
  font-weight: 950;
}

.source-item-active {
  border-color: rgba(246, 173, 85, 0.72);
  background: rgba(246, 173, 85, 0.18);
  color: #f8fafc;
}

.term-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.term-list text {
  min-height: 42rpx;
  margin: 0 10rpx 10rpx 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 850;
  line-height: 42rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 4rpx 20rpx;
  color: #f8fafc;
  font-size: 32rpx;
  font-weight: 950;
}

.section-head text:last-child {
  color: #8390a2;
  font-size: 22rpx;
  font-weight: 500;
}

.related-list {
  width: 100%;
}

.related-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 132rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-left-width: 8rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025)),
    #172231;
}

.related-code {
  flex: 0 0 78rpx;
  min-height: 42rpx;
  margin-right: 18rpx;
  border-radius: 12rpx;
  background: rgba(246, 173, 85, 0.13);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.related-main {
  flex: 1;
  min-width: 0;
}

.related-name {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-en {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #a9b5c7;
  font-size: 21rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-action {
  flex: 0 0 56rpx;
  margin-left: 16rpx;
  color: #53d4da;
  font-size: 22rpx;
  font-weight: 900;
  text-align: right;
}

.empty-state {
  padding: 64rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  background: #172231;
  text-align: center;
}

.empty-title,
.empty-copy {
  display: block;
}

.empty-title {
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 12rpx;
  color: #a9b5c7;
  font-size: 23rpx;
  line-height: 1.55;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.16);
  color: #ffcf85;
  font-size: 23rpx;
  font-weight: 900;
}
