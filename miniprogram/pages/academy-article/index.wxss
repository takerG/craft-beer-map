.academy-article-page {
  padding-bottom: 56rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(83, 212, 218, 0.16) 0, rgba(83, 212, 218, 0.05) 220rpx, transparent 410rpx),
    radial-gradient(circle at 90% 12%, rgba(246, 173, 85, 0.17) 0, rgba(246, 173, 85, 0.05) 210rpx, transparent 380rpx),
    linear-gradient(180deg, #101722 0%, #0d1118 58%, #10151d 100%);
}

.article-hero {
  padding: 34rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-top-width: 8rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025)),
    #172231;
  box-shadow: 0 22rpx 58rpx rgba(0, 0, 0, 0.24);
}

.article-kicker {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 900;
}

.article-hero .page-title {
  display: block;
  margin-top: 18rpx;
  color: #f8fafc;
  font-size: 46rpx;
  font-weight: 950;
  line-height: 1.18;
}

.article-hero .page-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #d6dfeb;
  font-size: 25rpx;
  line-height: 1.65;
}

.article-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.article-meta text {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  margin: 0 10rpx 10rpx 0;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #cbd5e1;
  font-size: 20rpx;
}

.module-tabs {
  width: 100%;
  margin-top: 26rpx;
  padding-bottom: 4rpx;
  white-space: nowrap;
}

.module-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-right: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.055);
  color: #aeb9c8;
  font-size: 22rpx;
  font-weight: 800;
}

.module-tab-active {
  border-color: rgba(255, 207, 133, 0.28);
  background: rgba(246, 173, 85, 0.18);
  color: #ffcf85;
}

.module-list {
  margin-top: 20rpx;
}

.module-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025)),
    #172231;
}

.module-card-active {
  border-color: rgba(255, 207, 133, 0.22);
  background:
    linear-gradient(135deg, rgba(246, 173, 85, 0.1), rgba(83, 212, 218, 0.05)),
    #1a2534;
}

.module-head {
  display: flex;
  align-items: center;
}

.module-type {
  flex: 0 0 auto;
  min-height: 34rpx;
  margin-right: 12rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(83, 212, 218, 0.12);
  color: #53d4da;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.module-title {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.module-summary {
  display: block;
  margin-top: 14rpx;
  color: #b8c4d3;
  font-size: 23rpx;
  line-height: 1.6;
}

.scale-list,
.mini-card-list,
.compare-list,
.quiz-panel {
  margin-top: 22rpx;
}

.scale-row {
  margin-bottom: 20rpx;
}

.scale-labels {
  display: flex;
  justify-content: space-between;
  color: #cbd5e1;
  font-size: 21rpx;
}

.scale-labels text:first-child {
  color: #f8fafc;
  font-weight: 900;
}

.scale-track {
  width: 100%;
  height: 16rpx;
  margin-top: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.scale-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #53d4da, #f6ad55);
}

.mini-card,
.compare-column,
.quiz-option {
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
}

.mini-index {
  display: inline-flex;
  color: #ffcf85;
  font-size: 20rpx;
  font-weight: 950;
}

.mini-title,
.compare-title,
.quiz-question {
  display: block;
  margin-top: 8rpx;
  color: #f8fafc;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.3;
}

.mini-body,
.compare-line {
  display: block;
  margin-top: 10rpx;
  color: #b8c4d3;
  font-size: 22rpx;
  line-height: 1.55;
}

.quiz-question {
  margin: 0 0 16rpx;
}

.quiz-option-selected {
  border-color: rgba(255, 207, 133, 0.35);
  background: rgba(246, 173, 85, 0.12);
}

.quiz-option-correct {
  border-color: rgba(52, 211, 153, 0.35);
  background: rgba(52, 211, 153, 0.1);
}

.quiz-label {
  display: block;
  color: #f8fafc;
  font-size: 24rpx;
  font-weight: 900;
}

.quiz-feedback {
  display: block;
  margin-top: 10rpx;
  color: #cbd5e1;
  font-size: 22rpx;
  line-height: 1.5;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 4rpx 20rpx;
  color: #f8fafc;
  font-size: 32rpx;
  font-weight: 950;
}

.section-head text:last-child {
  color: #8390a2;
  font-size: 22rpx;
  font-weight: 500;
}

.related-list {
  width: 100%;
}

.related-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 132rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-left-width: 8rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025)),
    #172231;
}

.related-code {
  flex: 0 0 78rpx;
  min-height: 42rpx;
  margin-right: 18rpx;
  border-radius: 12rpx;
  background: rgba(246, 173, 85, 0.13);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.related-main {
  flex: 1;
  min-width: 0;
}

.related-name {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-en {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #a9b5c7;
  font-size: 21rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-action {
  flex: 0 0 56rpx;
  margin-left: 16rpx;
  color: #53d4da;
  font-size: 22rpx;
  font-weight: 900;
  text-align: right;
}

.empty-state {
  padding: 64rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  background: #172231;
  text-align: center;
}

.empty-title,
.empty-copy {
  display: block;
}

.empty-title {
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 12rpx;
  color: #a9b5c7;
  font-size: 23rpx;
  line-height: 1.55;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.16);
  color: #ffcf85;
  font-size: 23rpx;
  font-weight: 900;
}
