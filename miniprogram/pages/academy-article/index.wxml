<view class="page academy-article-page">
  <view wx:if="{{isLoading}}" class="empty-state">
    <text>正在打开学院内容</text>
  </view>

  <view wx:if="{{isNotFound}}" class="empty-state">
    <text class="empty-title">没有找到这篇学院内容</text>
    <text class="empty-copy" user-select="true">可能是内容目录还没有生成，回到学院看看其他内容。</text>
    <view class="empty-action" hover-class="tap-hover" hover-stay-time="80" bindtap="backToAcademy">回到学院</view>
  </view>

  <view wx:if="{{isReady}}">
    <view class="article-hero" style="border-top-color: {{article.accent}}">
      <text class="article-kicker">{{article.hero.kicker}}</text>
      <text class="page-title">{{article.title}}</text>
      <text class="page-subtitle" user-select="true">{{article.hero.summary}}</text>
      <view class="article-meta">
        <text>{{article.difficulty}}</text>
        <text>{{article.readingTime}} min</text>
        <text>{{article.heroMetric}}</text>
      </view>
    </view>

    <view class="article-body">
      <view wx:for="{{articleSections}}" wx:for-item="section" wx:key="id" class="article-section">
        <text class="article-section-title">{{section.title}}</text>
        <text wx:for="{{section.paragraphs}}" wx:for-item="paragraph" wx:key="*this" class="article-paragraph" user-select="true">{{paragraph}}</text>
        <view wx:if="{{section.hasCallout}}" class="article-callout">
          <text>{{section.callout}}</text>
        </view>

        <view wx:if="{{section.showIpaMapExperience}}" class="ipa-map-experience experience-section">
          <view class="ipa-map-canvas">
            <view class="map-axis map-axis-x"></view>
            <view class="map-axis map-axis-y"></view>
            <text class="map-label map-label-left">清爽</text>
            <text class="map-label map-label-right">饱满</text>
            <text class="map-label map-label-top">香气强</text>
            <text class="map-label map-label-bottom">苦味利落</text>
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="ipa-node {{item.className}}"
              style="{{item.positionStyle}}"
              data-branch-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectIpaBranch"
            >
              <text>{{item.title}}</text>
            </view>
          </view>
          <view class="experience-focus">
            <text class="focus-title">{{article.experience.activeItem.title}}</text>
            <text class="focus-kicker">{{article.experience.activeItem.axis}}</text>
            <text class="focus-copy" user-select="true">{{article.experience.activeItem.body}}</text>
          </view>
        </view>

        <view wx:if="{{section.showAleLagerExperience}}" class="ale-lager-experience experience-section">
          <view class="path-switch">
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="path-option {{item.className}}"
              data-path-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectFermentationPath"
            >
              <text>{{item.title}}</text>
              <text user-select="true">{{item.lead}}</text>
            </view>
          </view>
          <view class="path-timeline">
            <view wx:for="{{article.experience.activeItem.steps}}" wx:for-item="step" wx:key="*this" class="path-step">
              <text class="step-dot"></text>
              <text user-select="true">{{step}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{section.showFlavorRadarExperience}}" class="flavor-radar-experience experience-section">
          <view class="radar-field">
            <view class="radar-ring radar-ring-outer"></view>
            <view class="radar-ring radar-ring-inner"></view>
            <view
              wx:for="{{article.experience.items}}"
              wx:key="id"
              class="source-orbit {{item.className}}"
              style="{{item.angleStyle}}"
              data-source-id="{{item.id}}"
              hover-class="tap-hover"
              hover-stay-time="80"
              bindtap="selectFlavorSource"
            >
              <text>{{item.title}}</text>
            </view>
          </view>
          <view class="term-board">
            <text class="focus-title">{{article.experience.activeItem.title}}</text>
            <text class="focus-copy" user-select="true">{{article.experience.activeItem.clue}}</text>
            <view class="term-list">
              <text wx:for="{{article.experience.activeItem.terms}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-head">
      <text>关联风格</text>
      <text>继续阅读</text>
    </view>

    <view class="related-list">
      <view
        wx:for="{{article.relatedStyles}}"
        wx:key="id"
        class="related-row"
        style="border-left-color: {{item.color}}"
        data-style-id="{{item.id}}"
        data-item-kind="{{item.kind}}"
        hover-class="tap-hover"
        hover-stay-time="80"
        bindtap="openRelatedStyle"
      >
        <text class="related-code">{{item.codeLabel}}</text>
        <view class="related-main">
          <text class="related-name">{{item.displayName}}</text>
          <text class="related-en" user-select="true">{{item.name_en}}</text>
        </view>
        <text class="related-action">查看</text>
      </view>
    </view>
  </view>
</view>
