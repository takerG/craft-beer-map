.style-language-page {
  padding-bottom: 56rpx;
  background:
    radial-gradient(circle at 8% 0%, rgba(83, 212, 218, 0.18) 0, rgba(83, 212, 218, 0.06) 230rpx, transparent 420rpx),
    radial-gradient(circle at 94% 18%, rgba(246, 173, 85, 0.18) 0, rgba(246, 173, 85, 0.05) 220rpx, transparent 400rpx),
    linear-gradient(180deg, #101722 0%, #0d1118 58%, #10151d 100%);
}

.language-hero {
  padding: 34rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(83, 212, 218, 0.18), rgba(246, 173, 85, 0.08)),
    #172231;
  box-shadow: 0 22rpx 58rpx rgba(0, 0, 0, 0.24);
}

.language-hero .page-title {
  display: block;
  color: #f8fafc;
  font-size: 44rpx;
  font-weight: 950;
  letter-spacing: 0;
  line-height: 1.2;
}

.language-hero .page-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #d6dfeb;
  font-size: 25rpx;
  line-height: 1.65;
}

.language-card-list {
  margin-top: 28rpx;
}

.language-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 154rpx;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-left-width: 10rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025)),
    #172231;
}

.language-card-active {
  border-color: rgba(255, 207, 133, 0.32);
  background:
    linear-gradient(120deg, rgba(246, 173, 85, 0.14), rgba(83, 212, 218, 0.08)),
    #1c2735;
}

.language-card-main {
  flex: 1;
  min-width: 0;
}

.language-title {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.language-subtitle {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #a9b5c7;
  font-size: 22rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.keyword-chip {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  margin: 0 8rpx 8rpx 0;
  padding: 0 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.055);
  color: #c9d4e3;
  font-size: 19rpx;
  line-height: 1.2;
}

.language-card-meta {
  flex: 0 0 86rpx;
  margin-left: 18rpx;
  text-align: right;
}

.language-card-meta text:first-child {
  display: block;
  color: #ffcf85;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1;
}

.language-card-meta text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #8d9aad;
  font-size: 20rpx;
}

.language-detail {
  margin-top: 34rpx;
}

.detail-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 0 4rpx 18rpx;
}

.detail-kicker {
  display: block;
  color: #f6ad55;
  font-size: 20rpx;
  font-weight: 900;
}

.detail-title {
  display: block;
  margin-top: 6rpx;
  color: #f8fafc;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.2;
}

.detail-count {
  color: #8d9aad;
  font-size: 22rpx;
  line-height: 1.4;
}

.detail-copy {
  display: block;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(83, 212, 218, 0.16);
  border-radius: 18rpx;
  background: rgba(83, 212, 218, 0.07);
  color: #dce5f2;
  font-size: 24rpx;
  line-height: 1.65;
}

.language-style-list {
  width: 100%;
}

.language-style-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 170rpx;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 18rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025)),
    #172231;
}

.style-code {
  flex: 0 0 78rpx;
  min-height: 42rpx;
  margin-right: 18rpx;
  padding: 0 10rpx;
  border-radius: 12rpx;
  background: rgba(246, 173, 85, 0.13);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.style-main {
  flex: 1;
  min-width: 0;
}

.style-name {
  display: block;
  overflow: hidden;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-alias {
  display: block;
  margin-top: 6rpx;
  color: #f6ad55;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.35;
}

.style-reason,
.style-caution {
  display: block;
  margin-top: 8rpx;
  color: #b8c4d3;
  font-size: 21rpx;
  line-height: 1.45;
}

.style-caution {
  color: #8d9aad;
}

.style-action {
  flex: 0 0 56rpx;
  margin-left: 16rpx;
  color: #53d4da;
  font-size: 22rpx;
  font-weight: 900;
  text-align: right;
}
