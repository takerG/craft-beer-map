<view class="page favorites-page">
  <view class="favorite-hero">
    <text class="page-title">收藏</text>
    <text class="page-subtitle">你标记过的 BJCP 风格会保存在本机，方便反复对照风味、参数和相关风格。</text>
    <view class="favorite-count">
      <text>{{favoriteCountLabel}}</text>
    </view>
  </view>

  <view wx:if="{{hasFavoriteStyles}}" class="favorite-list">
    <view
      wx:for="{{favoriteStyles}}"
      wx:key="id"
      class="favorite-row"
      style="border-left-color: {{item.color}}"
      hover-class="tap-hover"
      hover-stay-time="80"
      data-style-id="{{item.id}}"
      bindtap="openStyle"
    >
      <text class="favorite-code">{{item.code}}</text>
      <view class="favorite-main">
        <text class="favorite-name">{{item.displayName}}</text>
        <text class="favorite-en">{{item.name_en}}</text>
      </view>
      <text class="favorite-action">查看</text>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-title">还没有收藏的风格</text>
    <text class="empty-copy">打开任意 BJCP 风格详情，点右上角星标就会加入这里。</text>
    <view class="empty-action" hover-class="tap-hover" hover-stay-time="80" bindtap="goSearch">去搜索风格</view>
  </view>
</view>
