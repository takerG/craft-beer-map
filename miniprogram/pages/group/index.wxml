<view class="page group-page" wx:if="{{loadStatus === 'loading'}}">
  <view class="state-card">
    <text class="state-title">正在准备风格列表</text>
    <text class="state-copy">加载当前大类的类别与标准风格。</text>
  </view>
</view>

<view class="page group-page" wx:elif="{{loadStatus === 'error'}}">
  <view class="state-card">
    <text class="state-title">没有找到这个大类</text>
    <text class="state-copy">{{errorMessage}}</text>
    <view class="state-action" bindtap="goExplore">回到探寻</view>
  </view>
</view>

<view class="page group-page" wx:elif="{{group}}">
  <view class="group-hero" style="border-left-color: {{group.color}}">
    <text class="group-title">{{group.name}}</text>
    <text class="group-en">{{group.nameEn}}</text>
    <view class="group-stats">
      <text>{{group.categoryCount}} 类别</text>
      <text>{{group.styleCount}} 风格</text>
    </view>
  </view>

  <view class="section-head">
    <text>分类与风格</text>
  </view>

  <view class="category-list">
    <view wx:for="{{categories}}" wx:key="id" class="category-card">
      <view class="category-head">
        <text class="category-code">{{item.id}}</text>
        <view class="category-title">
          <text>{{item.name_zh}}</text>
          <text>{{item.name_en}}</text>
        </view>
        <text class="category-count">{{item.styleCount}}</text>
      </view>
      <view class="style-list">
        <view
          wx:for="{{item.styles}}"
          wx:for-item="style"
          wx:key="id"
          class="style-row"
          data-style-id="{{style.id}}"
          bindtap="openStyle"
        >
          <text class="style-code">{{style.code}}</text>
          <text class="style-name">{{style.displayName}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
