.group-page {
  padding-bottom: 64rpx;
}

.state-card {
  padding: 46rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
  text-align: center;
}

.state-title {
  display: block;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 800;
}

.state-copy {
  display: block;
  margin-top: 14rpx;
  color: #9aa8bb;
  font-size: 24rpx;
  line-height: 1.6;
}

.state-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.group-hero {
  position: relative;
  padding: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-left-width: 10rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(246, 173, 85, 0.18) 0, transparent 240rpx),
    linear-gradient(145deg, #202b3b 0%, #151f2c 68%, #101720 100%);
}

.group-title {
  display: block;
  color: #f8fafc;
  font-size: 40rpx;
  font-weight: 800;
}

.group-en {
  display: block;
  margin-top: 10rpx;
  color: #a9b5c7;
  font-size: 24rpx;
  line-height: 1.45;
}

.group-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.group-stats text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #dce5f2;
  font-size: 22rpx;
}

.section-head {
  margin: 36rpx 4rpx 18rpx;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 800;
}

.content-skeleton {
  margin-top: 18rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
}

.skeleton-line {
  height: 22rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.skeleton-line:first-child {
  margin-top: 0;
}

.skeleton-strong {
  width: 74%;
  background: rgba(255, 255, 255, 0.12);
}

.skeleton-short {
  width: 46%;
}

.category-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
}

.category-head {
  display: flex;
  align-items: center;
}

.category-code {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f6ad55;
  font-size: 24rpx;
  font-weight: 800;
}

.category-title {
  flex: 1;
  min-width: 0;
}

.category-title text:first-child {
  display: block;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 800;
}

.category-title text:last-child {
  display: block;
  margin-top: 6rpx;
  color: #9aa8bb;
  font-size: 21rpx;
}

.category-count {
  color: #9aa8bb;
  font-size: 22rpx;
}

.style-list {
  margin-top: 18rpx;
}

.style-row {
  display: flex;
  align-items: center;
  min-height: 70rpx;
  margin-top: 10rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.05);
  text-align: left;
}

.style-code {
  width: 64rpx;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}

.style-name {
  flex: 1;
  color: #e8eef7;
  font-size: 24rpx;
}
