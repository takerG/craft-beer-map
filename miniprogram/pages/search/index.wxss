.search-page {
  padding-bottom: 56rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 92rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: #182231;
}

.search-box input {
  flex: 1;
  color: #f8fafc;
  font-size: 28rpx;
}

.search-placeholder {
  color: #718096;
}

.clear-btn {
  display: flex;
  flex: 0 0 92rpx;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #cbd5e1;
  font-size: 22rpx;
  line-height: 56rpx;
  overflow: hidden;
}

.result-list {
  margin-top: 28rpx;
}

.empty-state {
  margin-top: 36rpx;
  padding: 42rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
  text-align: center;
}

.empty-title {
  display: block;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-copy {
  display: block;
  margin-top: 14rpx;
  color: #9aa8bb;
  font-size: 24rpx;
  line-height: 1.6;
}

.suggestion-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 24rpx;
}

.suggestion-chip {
  min-width: 104rpx;
  margin: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.result-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 132rpx;
  margin-bottom: 14rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: #182231;
  text-align: left;
}

.result-code {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 24rpx;
  font-weight: 800;
}

.result-kind {
  width: 104rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.result-name {
  display: block;
  color: #f8fafc;
  font-size: 28rpx;
  font-weight: 700;
}

.result-en {
  display: block;
  margin-top: 8rpx;
  color: #9aa8bb;
  font-size: 22rpx;
  line-height: 1.35;
}

.result-source {
  display: block;
  margin-top: 8rpx;
  color: #f6ad55;
  font-size: 21rpx;
  line-height: 1.35;
}

.result-alias-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.result-alias {
  margin: 0 8rpx 8rpx 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.12);
  color: #f6ad55;
  font-size: 20rpx;
  line-height: 1.3;
}
