.explore-page {
  padding-bottom: 56rpx;
}

.hero {
  padding: 32rpx;
  background: linear-gradient(150deg, #1d2a37 0%, #101820 62%, #1a242f 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.search-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 84rpx;
  margin-top: 28rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #cbd5e1;
  font-size: 26rpx;
  text-align: left;
}

.search-entry-icon {
  color: #f6ad55;
  font-size: 32rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 36rpx 4rpx 18rpx;
  color: #f8fafc;
  font-size: 30rpx;
  font-weight: 700;
}

.section-head text:last-child {
  color: #8390a2;
  font-size: 22rpx;
  font-weight: 500;
}

.group-grid {
  display: block;
  width: 100%;
}

.group-card {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  max-width: none;
  min-height: 132rpx;
  margin-bottom: 14rpx;
  padding: 18rpx 22rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-left-width: 8rpx;
  border-radius: 16rpx;
  background: #182231;
  text-align: left;
}

.group-card-bar {
  flex: 0 0 8rpx;
  width: 8rpx;
  height: 64rpx;
  margin-right: 18rpx;
  border-radius: 999rpx;
}

.group-card-main {
  flex: 1;
  min-width: 0;
}

.group-name {
  display: block;
  color: #f8fafc;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.25;
}

.group-en {
  display: block;
  margin-top: 6rpx;
  color: #a9b5c7;
  font-size: 21rpx;
  line-height: 1.35;
}

.group-card-meta {
  flex: 0 0 126rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  min-height: 64rpx;
  color: #cbd5e1;
  font-size: 22rpx;
}

.group-card-meta text + text {
  margin-top: 10rpx;
}

.featured-strip {
  width: 100%;
  white-space: nowrap;
}

.style-chip-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  width: 260rpx;
  min-height: 144rpx;
  margin-right: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: #182231;
  text-align: left;
  vertical-align: top;
}

.style-code {
  color: #f6ad55;
  font-size: 24rpx;
  font-weight: 800;
}

.style-name {
  display: block;
  margin-top: 12rpx;
  color: #f8fafc;
  font-size: 26rpx;
  font-weight: 700;
}

.style-en {
  display: block;
  margin-top: 8rpx;
  color: #9aa8bb;
  font-size: 20rpx;
  line-height: 1.3;
}
