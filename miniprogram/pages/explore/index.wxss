.explore-page {
  padding-bottom: 56rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(246, 173, 85, 0.26) 0, rgba(246, 173, 85, 0.08) 240rpx, transparent 430rpx),
    radial-gradient(circle at 92% 18%, rgba(83, 212, 218, 0.2) 0, rgba(83, 212, 218, 0.06) 210rpx, transparent 390rpx),
    linear-gradient(180deg, #111820 0%, #0d1118 56%, #10151d 100%);
}

.hero {
  position: relative;
  min-height: 480rpx;
  padding: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 28rpx;
  background:
    linear-gradient(135deg, rgba(255, 178, 76, 0.18) 0%, rgba(255, 122, 61, 0.05) 35%, transparent 64%),
    linear-gradient(155deg, #202632 0%, #111820 58%, #0b1017 100%);
  box-shadow: 0 26rpx 70rpx rgba(0, 0, 0, 0.28);
}

.hero-visual {
  position: absolute;
  top: 18rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  opacity: 0.92;
}

.hero-ring {
  position: absolute;
  border: 2rpx solid rgba(246, 173, 85, 0.4);
  border-radius: 999rpx;
}

.hero-glass {
  position: absolute;
  top: 96rpx;
  right: 132rpx;
  width: 112rpx;
  height: 188rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.48);
  border-top-width: 10rpx;
  border-radius: 18rpx 18rpx 34rpx 34rpx;
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 44rpx rgba(246, 173, 85, 0.22);
  transform: rotate(-7deg);
}

.hero-glass-head {
  position: absolute;
  top: 22rpx;
  left: 14rpx;
  width: 82rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 243, 215, 0.85);
}

.hero-glass-fill {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 126rpx;
  background: linear-gradient(180deg, #ffcf85 0%, #f6ad55 46%, #b95b22 100%);
}

.hero-glass-line {
  position: absolute;
  top: 64rpx;
  right: 22rpx;
  width: 10rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
}

.hero-ring-one {
  top: 22rpx;
  right: 34rpx;
  width: 270rpx;
  height: 270rpx;
  border-color: rgba(246, 173, 85, 0.34);
}

.hero-ring-two {
  top: 86rpx;
  right: 96rpx;
  width: 144rpx;
  height: 144rpx;
  border-color: rgba(83, 212, 218, 0.36);
}

.hero-spark {
  position: absolute;
  width: 72rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(246, 173, 85, 0), rgba(246, 173, 85, 0.92));
  transform: rotate(-28deg);
}

.hero-spark-one {
  top: 70rpx;
  right: 52rpx;
}

.hero-spark-two {
  top: 214rpx;
  right: 184rpx;
  width: 92rpx;
  background: linear-gradient(90deg, rgba(83, 212, 218, 0), rgba(83, 212, 218, 0.86));
}

.hero-copy {
  position: relative;
  z-index: 1;
  width: 74%;
}

.hero .page-title {
  font-size: 48rpx;
  letter-spacing: 0;
}

.hero .page-subtitle {
  margin-top: 16rpx;
  color: #d6dfeb;
  font-size: 25rpx;
  line-height: 1.72;
}

.hero-stats {
  position: relative;
  z-index: 1;
  display: flex;
  margin-top: 30rpx;
}

.hero-stat {
  flex: 1;
  min-width: 0;
  padding: 18rpx 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.hero-stat + .hero-stat {
  margin-left: 14rpx;
}

.hero-stat-value {
  display: block;
  color: #ffcf85;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-stat-label {
  display: block;
  margin-top: 10rpx;
  color: #aeb9c8;
  font-size: 21rpx;
  line-height: 1.25;
}

.search-entry {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 92rpx;
  margin-top: 26rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 207, 133, 0.2);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.09);
  color: #cbd5e1;
  font-size: 26rpx;
  text-align: left;
}

.language-entry {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 92rpx;
  margin-top: 16rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(83, 212, 218, 0.22);
  border-radius: 18rpx;
  background: rgba(83, 212, 218, 0.08);
  color: #cbd5e1;
  font-size: 26rpx;
  text-align: left;
}

.entry-hover {
  opacity: 0.88;
  border-color: rgba(246, 173, 85, 0.5);
  background: rgba(246, 173, 85, 0.14);
}

.search-copy {
  flex: 1;
  min-width: 0;
}

.search-label {
  display: block;
  color: #f8fafc;
  font-size: 26rpx;
  font-weight: 800;
}

.search-hint {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: #9ba8b8;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-entry-icon {
  color: #f6ad55;
  font-size: 44rpx;
  font-weight: 300;
}

.section-switch {
  display: flex;
  margin: 30rpx 0 4rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.05);
}

.section-tab {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 14rpx;
  color: #98a6b8;
  text-align: center;
}

.section-tab + .section-tab {
  margin-left: 8rpx;
}

.section-tab text:first-child {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-tab text:last-child {
  display: block;
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.2;
}

.section-tab-active {
  background: linear-gradient(135deg, rgba(246, 173, 85, 0.24), rgba(83, 212, 218, 0.12));
  color: #f8fafc;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.tab-hover {
  opacity: 0.88;
}

.section-panel {
  width: 100%;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 4rpx 20rpx;
  color: #f8fafc;
  font-size: 32rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #8390a2;
  font-size: 22rpx;
  font-weight: 500;
}

.group-grid {
  display: block;
  width: 100%;
}

.group-card {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  max-width: none;
  min-height: 164rpx;
  margin-bottom: 18rpx;
  padding: 22rpx 22rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-left-width: 10rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(118deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.025) 52%, rgba(255, 255, 255, 0.055)),
    #172231;
  box-shadow: 0 16rpx 30rpx rgba(0, 0, 0, 0.18);
  text-align: left;
}

.card-hover {
  opacity: 0.9;
  border-color: rgba(255, 255, 255, 0.26);
  background:
    linear-gradient(118deg, rgba(246, 173, 85, 0.12), rgba(83, 212, 218, 0.05)),
    #1c2735;
}

.group-card-glow {
  position: absolute;
  top: -86rpx;
  right: -40rpx;
  width: 230rpx;
  height: 230rpx;
  border-radius: 999rpx;
  opacity: 0.18;
}

.group-card-orbit {
  position: absolute;
  top: 22rpx;
  right: -14rpx;
  width: 160rpx;
  height: 160rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  opacity: 0.38;
  transform: rotate(-18deg);
}

.group-card-scan {
  position: absolute;
  right: 78rpx;
  bottom: 28rpx;
  width: 88rpx;
  height: 6rpx;
  border-radius: 999rpx;
  opacity: 0.48;
  transform: rotate(-22deg);
}

.group-card-bar {
  position: relative;
  z-index: 1;
  flex: 0 0 8rpx;
  width: 8rpx;
  height: 98rpx;
  margin-right: 20rpx;
  border-radius: 999rpx;
  box-shadow: 0 0 34rpx rgba(246, 173, 85, 0.24);
}

.group-card-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.group-code-pill {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.055);
}

.group-index {
  color: #aab6c7;
  font-size: 19rpx;
  font-weight: 900;
  line-height: 1;
}

.group-code-dot {
  width: 9rpx;
  height: 9rpx;
  margin-left: 8rpx;
  border-radius: 999rpx;
}

.group-name {
  display: block;
  margin-top: 12rpx;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.25;
}

.group-en {
  display: block;
  margin-top: 6rpx;
  color: #a9b5c7;
  font-size: 21rpx;
  line-height: 1.35;
}

.group-card-meta {
  position: relative;
  z-index: 1;
  flex: 0 0 118rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.meta-block {
  min-width: 86rpx;
  padding: 8rpx 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: rgba(8, 13, 20, 0.22);
  text-align: right;
}

.meta-block + .meta-block,
.meta-block + .meta-tag {
  margin-top: 8rpx;
}

.meta-value {
  display: inline;
  color: #f8fafc;
  font-size: 25rpx;
  font-weight: 950;
  line-height: 1;
}

.meta-label {
  display: inline;
  margin-left: 6rpx;
  color: #a8b5c5;
  font-size: 20rpx;
  font-weight: 700;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.12);
  color: #ffcf85;
  font-size: 20rpx;
  font-weight: 900;
}

.extension-intro {
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(246, 173, 85, 0.18);
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(246, 173, 85, 0.14), rgba(251, 113, 133, 0.08));
}

.extension-intro text {
  display: block;
  color: #dce5f2;
  font-size: 24rpx;
  line-height: 1.65;
}

.extension-group-card {
  background:
    linear-gradient(120deg, rgba(251, 113, 133, 0.08), rgba(255, 255, 255, 0.02)),
    #151f2c;
}

.extension-summary {
  display: block;
  margin-top: 10rpx;
  color: #8390a2;
  font-size: 21rpx;
  line-height: 1.45;
}

.featured-strip {
  width: 100%;
  padding-bottom: 4rpx;
  white-space: nowrap;
}

.style-chip-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  width: 286rpx;
  min-height: 164rpx;
  margin-right: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-top-width: 6rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
    #182231;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.15);
  text-align: left;
  vertical-align: top;
}

.chip-hover {
  opacity: 0.9;
  background:
    linear-gradient(145deg, rgba(246, 173, 85, 0.14), rgba(83, 212, 218, 0.05)),
    #1b2634;
}

.style-code {
  display: block;
  width: 100%;
  overflow: hidden;
  color: #f6ad55;
  font-size: 24rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-name {
  display: block;
  width: 100%;
  margin-top: 12rpx;
  overflow: hidden;
  color: #f8fafc;
  font-size: 26rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-en {
  display: block;
  width: 100%;
  margin-top: 8rpx;
  overflow: hidden;
  color: #9aa8bb;
  font-size: 20rpx;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}
