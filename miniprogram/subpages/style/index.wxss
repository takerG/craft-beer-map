.style-page {
  padding-bottom: 64rpx;
}

.state-card {
  padding: 46rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
  text-align: center;
}

.state-title {
  display: block;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 800;
}

.state-copy {
  display: block;
  margin-top: 14rpx;
  color: #9aa8bb;
  font-size: 24rpx;
  line-height: 1.6;
}

.state-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.style-hero {
  position: relative;
  padding: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-left-width: 10rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(246, 173, 85, 0.2) 0, transparent 250rpx),
    linear-gradient(145deg, #202b3b 0%, #151f2c 68%, #101720 100%);
}

.style-hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.style-code {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 24rpx;
  font-weight: 800;
}

.favorite-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 142rpx;
  height: 54rpx;
  margin-left: 18rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(246, 173, 85, 0.28);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffcf85;
  font-size: 23rpx;
  font-weight: 900;
}

.favorite-action-active {
  border-color: rgba(246, 173, 85, 0.64);
  background: rgba(246, 173, 85, 0.18);
  color: #ffe4b8;
}

.favorite-icon {
  margin-right: 8rpx;
  font-size: 25rpx;
  line-height: 1;
}

.style-name {
  display: block;
  margin-top: 22rpx;
  color: #f8fafc;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.2;
}

.style-en {
  display: block;
  margin-top: 10rpx;
  color: #a9b5c7;
  font-size: 25rpx;
  line-height: 1.45;
}

.style-path {
  display: block;
  margin-top: 24rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #dce5f2;
  font-size: 22rpx;
}

.style-path text:first-child {
  display: block;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}

.style-path text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #dce5f2;
  font-size: 22rpx;
  line-height: 1.4;
}

.content-skeleton {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #151f2c;
}

.skeleton-line {
  height: 22rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.skeleton-line:first-child {
  margin-top: 0;
}

.skeleton-strong {
  width: 76%;
  background: rgba(255, 255, 255, 0.12);
}

.skeleton-short {
  width: 48%;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 20rpx;
}

.stat-card {
  width: 49%;
  min-height: 92rpx;
  margin-bottom: 14rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: #182231;
}

.stat-card text:first-child {
  display: block;
  color: #9aa8bb;
  font-size: 20rpx;
}

.stat-card text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #f8fafc;
  font-size: 26rpx;
  font-weight: 800;
}

.detail-section {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
}

.reading-section {
  margin-top: 20rpx;
  padding: 30rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #151f2c;
}

.detail-title {
  display: block;
  color: #f6ad55;
  font-size: 25rpx;
  font-weight: 800;
}

.detail-body {
  display: block;
  margin-top: 18rpx;
  color: #e8eef7;
  font-size: 27rpx;
  line-height: 1.88;
  white-space: pre-wrap;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #dce5f2;
  font-size: 22rpx;
}

.alias-section {
  margin-top: 20rpx;
}

.alias-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.alias {
  margin: 0 12rpx 12rpx 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 22rpx;
  line-height: 1.3;
}

.related-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 72rpx;
  margin-top: 12rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.05);
  text-align: left;
}

.related-type {
  width: 112rpx;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}

.related-name {
  flex: 1;
  min-width: 0;
  color: #e8eef7;
  font-size: 24rpx;
  line-height: 1.35;
}

.related-action {
  margin-left: 12rpx;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}
