.extension-style-page {
  padding-bottom: 64rpx;
}

.state-card {
  padding: 46rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #182231;
  text-align: center;
}

.state-title {
  display: block;
  color: #f8fafc;
  font-size: 31rpx;
  font-weight: 800;
}

.state-copy {
  display: block;
  margin-top: 14rpx;
  color: #9aa8bb;
  font-size: 24rpx;
  line-height: 1.6;
}

.state-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.style-hero {
  position: relative;
  padding: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-left-width: 10rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(251, 113, 133, 0.2) 0, transparent 250rpx),
    linear-gradient(145deg, #202b3b 0%, #151f2c 68%, #101720 100%);
}

.style-code {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 23rpx;
  font-weight: 800;
}

.style-name {
  display: block;
  margin-top: 22rpx;
  color: #f8fafc;
  font-size: 42rpx;
  font-weight: 850;
  line-height: 1.2;
}

.style-en,
.style-source {
  display: block;
  margin-top: 10rpx;
  color: #a9b5c7;
  font-size: 25rpx;
  line-height: 1.45;
}

.style-source {
  color: #f6ad55;
  font-weight: 800;
}

.style-path {
  display: block;
  margin-top: 24rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #dce5f2;
  font-size: 22rpx;
}

.style-path text:first-child {
  display: block;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}

.style-path text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #dce5f2;
  font-size: 22rpx;
  line-height: 1.4;
}

.content-skeleton {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #151f2c;
}

.skeleton-line {
  height: 22rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
}

.skeleton-line:first-child {
  margin-top: 0;
}

.skeleton-strong {
  width: 76%;
  background: rgba(255, 255, 255, 0.12);
}

.skeleton-short {
  width: 48%;
}

.detail-section,
.reading-section {
  margin-top: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: #151f2c;
}

.detail-title {
  display: block;
  color: #f6ad55;
  font-size: 25rpx;
  font-weight: 800;
}

.detail-body {
  display: block;
  margin-top: 18rpx;
  color: #e8eef7;
  font-size: 27rpx;
  line-height: 1.88;
}

.alias-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.alias {
  margin: 0 12rpx 12rpx 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 22rpx;
  line-height: 1.3;
}

.bjcp-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 82rpx;
  margin-top: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.06);
  text-align: left;
}

.bjcp-code {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 56rpx;
  margin-right: 16rpx;
  border-radius: 10rpx;
  background: rgba(246, 173, 85, 0.14);
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}

.bjcp-main {
  flex: 1;
  min-width: 0;
}

.bjcp-name {
  display: block;
  color: #f8fafc;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.3;
}

.bjcp-en {
  display: block;
  margin-top: 6rpx;
  color: #9aa8bb;
  font-size: 21rpx;
  line-height: 1.35;
}

.bjcp-action {
  margin-left: 14rpx;
  color: #f6ad55;
  font-size: 22rpx;
  font-weight: 800;
}
