page {
  min-height: 100%;
  background: #10151d;
  color: #eef2f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans SC", sans-serif;
}

view,
text,
button,
input,
scroll-view,
canvas {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
  color: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #10151d;
}

.page-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #f8fafc;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #a9b5c7;
  font-size: 24rpx;
  line-height: 1.6;
}

.surface {
  background: #182231;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.muted {
  color: #9aa8bb;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #dce5f2;
  font-size: 22rpx;
}

.empty {
  padding: 48rpx 24rpx;
  color: #9aa8bb;
  text-align: center;
  font-size: 26rpx;
}

.share-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 207, 133, 0.34);
  border-radius: 999rpx;
  background: rgba(246, 173, 85, 0.1);
  color: #ffcf85;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 50rpx;
}
